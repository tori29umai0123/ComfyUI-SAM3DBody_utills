# ==========================================================================
# Python
# ==========================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/blender/
lib64/
parts/
sdist/
var/
wheels/
# Top-level wheels/ ships prebuilt aarch64 + cu130 wheels for DGX Spark / GH200.
!/wheels/
!/wheels/**
*.egg-info/
.installed.cfg
*.egg

# ==========================================================================
# Virtual environments
# ==========================================================================
venv/
ENV/
env/
.venv/

# comfy-env isolated runtime — built by install.py, GB-scale.
_env_*/

# comfy-env / pixi internals
.pixi/
pixi.lock
pixi.toml
.comfy-env-marker.toml

# ==========================================================================
# IDE / OS
# ==========================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.ipynb_checkpoints/
.DS_Store
Thumbs.db

# ==========================================================================
# Claude Code (per-user local settings — never commit)
# ==========================================================================
.claude/

# ==========================================================================
# Model checkpoints
# ==========================================================================
# SAM 3D Body weights live in <ComfyUI>/models/sam3dbody/, never in this
# repo — but guard against accidental drops.
*.ckpt
*.pth
*.pt
checkpoints/
.cache/

# ==========================================================================
# Runtime-generated outputs (never tracked)
# ==========================================================================
output/
*.glb
*.gltf
*.ply
*.log
wandb/
tmp/
temp/
*.tmp

# ==========================================================================
# Testing
# ==========================================================================
.pytest_cache/
.coverage
htmlcov/
.tox/
*.cover
.hypothesis/
.comfy-test-logs/

# ==========================================================================
# User-local runtime state
# ==========================================================================
# `autosave.json` is rewritten at the end of every render call, so
# it's user-local state rather than source. The named presets (female /
# male / reset / etc.) ARE tracked. Pattern covers any preset pack
# (default, custom, ...).
presets/*/chara_settings_presets/autosave.json

# ==========================================================================
# Explicit allow-list — files/paths that earlier versions of this
# .gitignore erroneously excluded
# ==========================================================================
# `web/js/autosave_apply.js` is part of this extension, not a generated
# viewer bundle. `tools/bone_backup/mhr_reference.obj` is the reference
# mesh shipped with the package. Don't add `web/` or `*.obj` patterns.

# editor runtime tmp (mesh.obj / mask.png written by /sam3d/api/process)
nodes/editor_tmp/

# ==========================================================================
# Migration / config backups (never commit)
# ==========================================================================
# Created by tools/migrate_workflows.py and tools/strip_process_image_output.py
*.bak
*.bak-*
